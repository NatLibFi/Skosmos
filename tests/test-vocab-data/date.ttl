@prefix dc: <http://purl.org/dc/terms/> .
@prefix date: <http://www.skosmos.skos/date/> .
@prefix meta: <http://www.skosmos.skos/test-meta/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix skosmos: <http://www.skosmos.skos/> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

date:d1 a skos:Concept, meta:TestClass ;
    dc:created "2000-01-03T12:46:39+03:00"^^xsd:dateTime ;
    dc:modified "2012-06-06T12:46:39+03:00"^^xsd:dateTime ;
    date:ownDate "2015-08-08T12:46:39+03:00"^^xsd:dateTime ;
    skos:prefLabel "A date"@en .

date:d2 a skos:Concept, meta:TestClass ;
    date:ownDate "1986-21-00"^^xsd:date ; #invalid on purpose
    skos:prefLabel "Broken date"@en .

# Test concept with date-only (no time component, midnight)
date:d3 a skos:Concept ;
    dc:created "2020-05-15T00:00:00+00:00"^^xsd:dateTime ;
    dc:modified "2022-11-30T00:00:00+00:00"^^xsd:dateTime ;
    skos:prefLabel "Date without time"@en .

# Test concept with date+time (non-midnight time)
date:d4 a skos:Concept ;
    dc:created "2021-03-10T14:30:45+01:00"^^xsd:dateTime ;
    dc:modified "2023-07-20T09:15:30-05:00"^^xsd:dateTime ;
    skos:prefLabel "Date with time"@en .

# Test concept with timezone conversion (Paris time -> should convert to UTC in tests)
date:d5 a skos:Concept ;
    dc:created "2024-01-15T18:45:00+01:00"^^xsd:dateTime ;
    dc:modified "2024-02-20T22:30:00+01:00"^^xsd:dateTime ;
    skos:prefLabel "Date for timezone test"@en .

date:ownDate a owl:DatatypeProperty ;
  rdfs:label "This is also a dateTime" .

<http://www.skosmos.skos/date/> a owl:Ontology ;
    rdfs:label "<http://www.skosmos.skos/date/>"^^xsd:string ;
    owl:versionInfo "$Id: date.ttl 1197 2016-02-11j14:05:26Z someone@skosmos.skos $"^^xsd:string .
